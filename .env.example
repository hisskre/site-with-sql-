DB_HOST=localhost
DB_PORT=5432
DB_NAME=instructions_db
DB_USER=instr-api-user
DB_PASSWORD=replace-with-a-strong-password

# Used by Docker Compose for the PostgreSQL administrator account.
POSTGRES_PASSWORD=replace-with-a-strong-postgres-admin-password

# Comma-separated website origins allowed to call the API from a browser.
API_CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://localhost:3000,http://localhost:5173

DB_POOL_MIN_SIZE=1
DB_POOL_MAX_SIZE=10
DB_POOL_TIMEOUT=5
